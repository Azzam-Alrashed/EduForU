---
const steps = [
  {
    number: '١',
    title: 'تقييم سريع',
    description: 'اختبار قصير يحدّد مستواك وأهدافك في البرمجة — بدون تعقيد.',
  },
  {
    number: '٢',
    title: 'خطة أسبوعية',
    description: 'مسار شخصي بالعربي: ماذا تتعلّم هذا الأسبوع وما المهام اليومية.',
  },
  {
    number: '٣',
    title: 'مدرس عند الحاجة',
    description: 'عندما تتعثر، احجز مدرسًا يرى مسارك ونقاط ضعفك ويساعدك مباشرة.',
  },
];
---

<section id="how-it-works" class="px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-navy sm:text-4xl">كيف يعمل EduForU؟</h2>
      <p class="mt-4 text-lg text-slate-600">ثلاث خطوات من الفكرة إلى أول مشروع برمجي</p>
    </div>

    <div class="relative mt-12 grid gap-8 lg:grid-cols-3">
      <div class="absolute top-12 hidden h-0.5 w-full bg-gradient-to-l from-teal/20 via-teal to-teal/20 lg:block" aria-hidden="true"></div>

      {
        steps.map((step, i) => (
          <article
            class:list={[
              'relative animate-fade-in-up text-center',
              i === 1 && 'animate-delay-1',
              i === 2 && 'animate-delay-2',
            ]}
          >
            <div class="relative z-10 mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-teal text-2xl font-bold text-navy shadow-lg shadow-teal/30">
              {step.number}
            </div>
            <h3 class="mt-6 text-xl font-bold text-navy">{step.title}</h3>
            <p class="mt-3 leading-relaxed text-slate-600">{step.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
